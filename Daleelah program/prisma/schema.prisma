generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  role      Role
  isSuspended Boolean  @default(false)
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  touristBookings Booking[]     @relation("TouristBookings")
  guideBookings   Booking[]     @relation("GuideBookings")
  guideTours      Tour[]        @relation("GuideTours")
  companyOffers   Offer[]
  companyListings Listing[]
  reviews         Review[]
  announcements   Announcement[]
  guideProfile    GuideProfile?

  @@map("users")
}

enum Role {
  TOURIST
  GUIDE
  COMPANY
  MINISTRY
}

model Destination {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  city        String
  region      String
  category    String
  summary     String   @db.Text
  description String   @db.Text
  images      Json
  tags        Json
  rating      Float    @default(0)
  status      Status   @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]
  reviews  Review[]

  @@map("destinations")
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

model GuideProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  bio             String   @db.Text
  specialties     Json
  languages       Json
  pricePerHour    Int
  rating          Float    @default(0)
  totalTours      Int      @default(0)
  experienceYears Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("guide_profiles")
}

model Booking {
  id            String        @id @default(uuid())
  touristId     String
  guideId       String?
  destinationId String
  startDate     DateTime
  endDate       DateTime
  status        BookingStatus @default(PENDING)
  totalPrice    Int
  participants  Int           @default(1)
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tourist     User        @relation("TouristBookings", fields: [touristId], references: [id])
  guide       User?       @relation("GuideBookings", fields: [guideId], references: [id])
  destination Destination @relation(fields: [destinationId], references: [id])

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Tour {
  id              String     @id @default(uuid())
  guideId         String
  title           String
  description     String     @db.Text
  location        String
  date            DateTime
  time            String
  duration        String
  price           Int
  maxParticipants Int
  status          TourStatus @default(UPCOMING)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  guide User @relation("GuideTours", fields: [guideId], references: [id])

  @@map("tours")
}

enum TourStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model Review {
  id            String   @id @default(uuid())
  userId        String
  destinationId String?
  guideId       String?
  rating        Int
  comment       String   @db.Text
  images        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  destination Destination? @relation(fields: [destinationId], references: [id])

  @@map("reviews")
}

model Offer {
  id              String   @id @default(uuid())
  companyId       String
  title           String
  description     String   @db.Text
  originalPrice   Int
  discountedPrice Int
  discount        Int
  validFrom       DateTime
  validUntil      DateTime
  active          Boolean  @default(true)
  bookingsCount   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company User @relation(fields: [companyId], references: [id])

  @@map("offers")
}

model Listing {
  id              String        @id @default(uuid())
  companyId       String
  title           String
  type            ListingType
  description     String        @db.Text
  price           Int
  duration        String
  maxParticipants Int
  status          ListingStatus @default(DRAFT)
  bookingsCount   Int           @default(0)
  rating          Float         @default(0)
  image           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company User @relation(fields: [companyId], references: [id])

  @@map("listings")
}

enum ListingType {
  TOUR
  PACKAGE
  ACTIVITY
}

enum ListingStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

model Announcement {
  id          String               @id @default(uuid())
  ministryId  String
  title       String
  content     String               @db.Text
  category    AnnouncementCategory
  status      AnnouncementStatus   @default(DRAFT)
  views       Int                  @default(0)
  publishDate DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  ministry User @relation(fields: [ministryId], references: [id])

  @@map("announcements")
}

enum AnnouncementCategory {
  REGULATION
  EVENT
  UPDATE
  ALERT
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}